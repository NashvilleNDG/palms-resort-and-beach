# Optional: override Web3Forms keys (fallbacks are set in code so forms work without this file)
# Copy to .env.local only if you want to use different keys.

# Base URL for sitemap and canonical URLs
# NEXT_PUBLIC_BASE_URL=https://palmsresortbeach.com

# Contact page form — one key
# NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=

# Footer newsletter + email popup — same key for both
# NEXT_PUBLIC_WEB3FORMS_NEWSLETTER_ACCESS_KEY=
